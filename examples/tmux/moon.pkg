import {
  "moonbit-community/pty",
  "moonbit-community/tty",
  "moonbit-community/tty/input" @tty/input,
  "moonbitlang/async",
  "moonbitlang/async/aqueue",
  "moonbitlang/async/io" @async/io,
  "moonbitlang/core/buffer",
  "moonbitlang/core/cmp",
